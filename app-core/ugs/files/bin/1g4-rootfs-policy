#!/bin/bash

set -euo pipefail

usage() {
	cat <<- EOF
	Usage:
	  $(basename "$0") finalize ROOT MODE
	  $(basename "$0") validate ROOT MODE

	MODE:
	  bootable   apply bootable-host policy
	  stage      apply stage/chroot artifact policy
	EOF
}

die() {
	echo "$(basename "$0"): $*" >&2
	exit 1
}

log() {
	echo "[$(basename "$0")] $*"
}

command -v systemctl >/dev/null 2>&1 || die "systemctl is required"

[[ $# -eq 3 ]] || {
	usage >&2
	exit 2
}

ACTION=${1}
ROOT=${2}
MODE=${3}

case ${ACTION} in
	finalize|validate) ;;
	*)
		usage >&2
		exit 2
		;;
esac

case ${MODE} in
	bootable|stage) ;;
	*)
		usage >&2
		exit 2
		;;
esac

ROOT=${ROOT%/}
[[ -n ${ROOT} ]] || ROOT=/
[[ -d ${ROOT} ]] || die "root does not exist: ${ROOT}"

root_path() {
	local rel=${1}
	if [[ ${ROOT} == / ]]; then
		printf '/%s\n' "${rel#/}"
	else
		printf '%s/%s\n' "${ROOT}" "${rel#/}"
	fi
}

root_relative_path() {
	local abs=${1}
	if [[ ${ROOT} == / ]]; then
		printf '/%s\n' "${abs#/}"
	else
		printf '/%s\n' "${abs#"${ROOT}/"}"
	fi
}

path_recorded_in_vdb() {
	local query=${1} contents
	shopt -s nullglob
	for contents in "$(root_path /var/db/pkg)"/*/*/CONTENTS; do
		[[ -f ${contents} ]] || continue
		if awk -v path="${query}" '$2 == path { found=1; exit 0 } END { exit(found ? 0 : 1) }' "${contents}"; then
			return 0
		fi
	done
	return 1
}

has_unit() {
	local unit=${1}
	[[ -e $(root_path "/usr/lib/systemd/system/${unit}") ]] || [[ -e $(root_path "/etc/systemd/system/${unit}") ]]
}

has_exec() {
	local rel=${1}
	[[ -x $(root_path "${rel}") ]]
}

resolve_payload_ready() {
	has_unit systemd-resolved.service &&
	has_exec /usr/lib/systemd/systemd-resolved &&
	has_exec /usr/bin/resolvectl
}

networkd_payload_ready() {
	has_unit systemd-networkd.service &&
	has_exec /usr/lib/systemd/systemd-networkd
}

chronyd_payload_ready() {
	has_unit chronyd.service &&
	has_exec /usr/bin/chronyd
}

unit_enabled() {
	local unit=${1}
	systemctl_root is-enabled "${unit}" >/dev/null 2>&1
}

remove_unit_enablement() {
	local unit=${1} link target
	[[ -d $(root_path /etc/systemd/system) ]] || return 0
	while IFS= read -r -d '' link; do
		target=$(readlink "${link}" || true)
		[[ -n ${target} ]] || continue
		case ${target##*/} in
			"${unit}") rm -f "${link}" ;;
		esac
	done < <(find "$(root_path /etc/systemd/system)" -type l -print0 2>/dev/null)
}

unit_link_present() {
	local unit=${1} link target
	[[ -d $(root_path /etc/systemd/system) ]] || return 1
	while IFS= read -r -d '' link; do
		target=$(readlink "${link}" || true)
		[[ -n ${target} ]] || continue
		case ${target##*/} in
			"${unit}") return 0 ;;
		esac
	done < <(find "$(root_path /etc/systemd/system)" -type l -print0 2>/dev/null)
	return 1
}

systemctl_root() {
	SYSTEMD_OFFLINE=1 systemctl --root="${ROOT}" --no-reload "$@"
}

apply_preset_if_present() {
	local unit=${1}
	if has_unit "${unit}"; then
		systemctl_root preset "${unit}" >/dev/null
	else
		remove_unit_enablement "${unit}"
	fi
}

write_factory_resolv_conf() {
	local dst factory
	dst=$(root_path /etc/resolv.conf)
	factory=$(root_path /usr/share/factory/etc/resolv.conf)
	install -d "$(dirname "${dst}")"
	rm -f "${dst}"
	if [[ -f ${factory} ]]; then
		install -m0644 "${factory}" "${dst}"
	else
		cat > "${dst}" <<- EOF
			# Resolver configuration file.
			# See resolv.conf(5) for details.
		EOF
	fi
}

finalize_resolv_conf() {
	local dst
	dst=$(root_path /etc/resolv.conf)
	if resolve_payload_ready && [[ ${MODE} == bootable ]]; then
		install -d "$(dirname "${dst}")"
		rm -f "${dst}"
		ln -snf ../run/systemd/resolve/stub-resolv.conf "${dst}"
	else
		write_factory_resolv_conf
	fi
}

write_default_networkd_config() {
	local dir managed legacy
	dir=$(root_path /etc/systemd/network)
	managed="${dir}/80-1g4-default-dhcp.network"
	legacy="${dir}/80-host0.network"

	install -d "${dir}"

	if [[ -f ${legacy} ]] && ! path_recorded_in_vdb /etc/systemd/network/80-host0.network; then
		rm -f "${legacy}"
	fi

	shopt -s nullglob
	local network_files=("${dir}"/*.network)
	if (( ${#network_files[@]} == 0 )); then
		cat > "${managed}" <<- EOF
			# Generated by 1g4 rootfs finalizer.
			# Remove or replace this file to manage networking manually.
			[Match]
			Name=host0 en* eth*

			[Network]
			DHCP=ipv4
			IPv6AcceptRA=no

			[DHCPv4]
			UseDNS=yes
			UseRoutes=yes
		EOF
	fi
}

apply_network_policy() {
	if networkd_payload_ready; then
		write_default_networkd_config
	fi
}

apply_service_policy() {
	apply_preset_if_present getty@tty1.service
	apply_preset_if_present remote-fs.target
	apply_preset_if_present systemd-networkd.service
	apply_preset_if_present systemd-networkd-wait-online.service
	apply_preset_if_present systemd-resolved.service
	apply_preset_if_present chronyd.service
	remove_unit_enablement systemd-timesyncd.service
}

validate_enabled_preset_targets() {
	local preset line verb unit
	shopt -s nullglob
	for preset in \
		"$(root_path /usr/lib/systemd/system-preset)"/*.preset \
		"$(root_path /usr/lib/systemd/initrd-preset)"/*.preset
	do
		[[ -f ${preset} ]] || continue
		while IFS= read -r line; do
			read -r verb unit _ <<< "${line}"
			[[ -n ${verb:-} && -n ${unit:-} ]] || continue
			[[ ${verb} == enable ]] || continue
			case ${unit} in
				*\**|*\?*) continue ;;
			esac
			has_unit "${unit}" || die "preset enables missing unit: ${unit} (${preset})"
		done < <(grep -Ev '^[[:space:]]*(#|$)' "${preset}")
	done
}

validate_resolv_conf() {
	local resolv
	resolv=$(root_path /etc/resolv.conf)
	[[ -e ${resolv} ]] || die "/etc/resolv.conf is missing"

	if [[ -f ${resolv} ]] && grep -qs '^# This is /run/systemd/resolve/stub-resolv.conf managed by man:systemd-resolved(8)\.' "${resolv}"; then
		die "/etc/resolv.conf is a resolved stub regular file, expected a symlink or plain resolver file"
	fi

	if resolve_payload_ready; then
		if [[ ${MODE} == bootable ]]; then
			unit_enabled systemd-resolved.service || die "systemd-resolved.service is not enabled in a bootable resolved image"
			[[ -L ${resolv} ]] || die "/etc/resolv.conf is not a symlink in a bootable resolved image"
			[[ $(readlink "${resolv}") == ../run/systemd/resolve/stub-resolv.conf ]] || die "/etc/resolv.conf points at the wrong target"
		else
			[[ ! -L ${resolv} ]] || die "/etc/resolv.conf is a symlink in a stage artifact that will not run resolved yet"
		fi
	else
		if unit_enabled systemd-resolved.service || unit_link_present systemd-resolved.service; then
			die "systemd-resolved.service is enabled without resolved payload support"
		fi
		[[ ! -L ${resolv} ]] || die "/etc/resolv.conf is a symlink but this image does not expect runtime resolved stubs"
	fi
}

validate_service_policy() {
	(unit_enabled systemd-timesyncd.service || unit_link_present systemd-timesyncd.service) &&
		die "systemd-timesyncd.service appears enabled"

	if [[ ${MODE} == bootable ]]; then
		chronyd_payload_ready || die "chronyd.service payload is missing from a bootable image"
		unit_enabled chronyd.service || die "chronyd.service is not enabled in a bootable image"
	fi

	if networkd_payload_ready && ! unit_enabled systemd-networkd.service; then
		die "systemd-networkd.service payload exists but is not enabled"
	fi
}

validate_network_policy() {
	local dir file rel
	dir=$(root_path /etc/systemd/network)
	[[ -d ${dir} ]] || return 0
	shopt -s nullglob
	for file in "${dir}"/*.network; do
		[[ -f ${file} ]] || continue
		rel=$(root_relative_path "${file}")
		if path_recorded_in_vdb "${rel}"; then
			continue
		fi
		if grep -qs '^# Generated by 1g4 rootfs finalizer\.$' "${file}"; then
			continue
		fi
		die "unowned networkd config with unclear origin: ${rel}"
	done
}

validate_contents_consistency() {
	local contents type path _rest
	shopt -s nullglob
	for contents in "$(root_path /var/db/pkg)"/*/*/CONTENTS; do
		[[ -f ${contents} ]] || continue
		while read -r type path _rest; do
			[[ -n ${path:-} ]] || continue
			case ${path} in
				/var/log/journal|/var/log/journal/*|/var/log/.keep_*|/var/log/old|/var/log/old/*)
					die "volatile log path still recorded in CONTENTS: ${path} (${contents})"
					;;
			esac
			case ${path} in
				/usr/share/man|/usr/share/man/*|/usr/share/doc|/usr/share/doc/*|/usr/share/info|/usr/share/info/*|/usr/share/gtk-doc|/usr/share/gtk-doc/*|/usr/share/ri|/usr/share/ri/*)
					if [[ ! -e $(root_path "${path}") ]]; then
						die "post-pruned path still recorded in CONTENTS: ${path} (${contents})"
					fi
					;;
			esac
		done < "${contents}"
	done
}

finalize_root() {
	apply_service_policy
	finalize_resolv_conf
	apply_network_policy
}

validate_root() {
	validate_enabled_preset_targets
	validate_service_policy
	validate_resolv_conf
	validate_network_policy
	validate_contents_consistency
}

case ${ACTION} in
	finalize)
		finalize_root
		validate_root
		log "finalized ${ROOT} (${MODE})"
		;;
	validate)
		validate_root
		log "validated ${ROOT} (${MODE})"
		;;
esac
