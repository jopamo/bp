+
+DEFINE_STATIC_KEY_FALSE(net_txq_trace_key);
+
+static bool net_txq_trace_param;
+
+static int net_txq_trace_enable_set(const char *val,
+				    const struct kernel_param *kp)
+{
+	bool enable;
+	int ret;
+
+	ret = kstrtobool(val, &enable);
+	if (ret)
+		return ret;
+
+	if (enable == READ_ONCE(net_txq_trace_param))
+		return 0;
+
+	if (enable)
+		static_branch_enable(&net_txq_trace_key);
+	else
+		static_branch_disable(&net_txq_trace_key);
+
+	WRITE_ONCE(net_txq_trace_param, enable);
+	return 0;
+}
+
+static const struct kernel_param_ops net_txq_trace_param_ops = {
+	.set = net_txq_trace_enable_set,
+	.get = param_get_bool,
+};
+
+module_param_cb(txq_trace_enable, &net_txq_trace_param_ops,
+		&net_txq_trace_param, 0600);
+MODULE_PARM_DESC(txq_trace_enable,
+		 "enable detailed TX queue/BQL kernel tracepoints");
+
+static u16 netdev_txq_trace_index(const struct netdev_queue *txq)
+{
+	if (!txq || !txq->dev || !txq->dev->_tx)
+		return 0;
+
+	return txq - txq->dev->_tx;
+}
+
+static u32
+netdev_txq_trace_inflight(const struct netdev_txq_trace_dql_snapshot *snap)
+{
+	if (!snap)
+		return 0;
+
+	return snap->num_queued >= snap->num_completed ?
+	       snap->num_queued - snap->num_completed : 0;
+}
+
+void netdev_txq_trace_stop(
+	struct netdev_queue *txq, unsigned long caller,
+	unsigned long state_before, unsigned long state_after,
+	const struct netdev_txq_trace_dql_snapshot *snap)
+{
+	trace_net_dev_txq_stop(txq, netdev_txq_trace_index(txq), caller, true,
+			       state_before, state_after, snap->num_queued,
+			       snap->num_completed,
+			       netdev_txq_trace_inflight(snap), snap->limit,
+			       snap->adj_limit, snap->avail);
+}
+
+void netdev_txq_trace_wake(
+	struct netdev_queue *txq, unsigned long caller, bool did_wake,
+	unsigned long state_before, unsigned long state_after,
+	const struct netdev_txq_trace_dql_snapshot *snap)
+{
+	trace_net_dev_txq_wake(txq, netdev_txq_trace_index(txq), caller,
