             compile_check_conftest "$CODE" "NV_DRM_FBDEV_TTM_SETUP_PRESENT" "" "functions"
         ;;
 
+        drm_atomic_commit_put)
+            #
+            # Determine whether drm_atomic_commit_put() is present.
