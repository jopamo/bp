# /etc/env.d/50layout

MANPATH="/usr/local/share/man:/usr/share/man"
INFOPATH="/usr/share/info"
# Keep /usr/local first so locally installed shared libraries are visible to
# the system dynamic linker without extra manual ld.so.conf edits.
LDPATH="/usr/local/lib:/usr/lib"
PATH="/usr/local/bin:/usr/bin:/opt/bin:/usr/local/sbin:/usr/sbin"
