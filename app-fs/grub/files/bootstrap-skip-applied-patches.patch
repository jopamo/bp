diff --git a/bootstrap.conf b/bootstrap.conf
--- a/bootstrap.conf
+++ b/bootstrap.conf
@@ -80,25 +80,44 @@ cp -a INSTALL INSTALL.grub
 bootstrap_post_import_hook () {
   set -e
 
-  # Instead of patching our gnulib and therefore maintaining a fork, submit
-  # changes to gnulib and update the hash above when they've merged.  Do not
-  # add new patches here.
-  for patchname in fix-width \
-      fix-regcomp-resource-leak \
-      fix-regexec-resource-leak \
-      fix-gcc-15-compile \
-      fix-unused-value; do
-    patch -d grub-core/lib/gnulib -p2 \
-       < "grub-core/lib/gnulib-patches/$patchname.patch"
-  done
+  check_for_rejects () {
+    patchdir=$1
+    reject=$(find "$patchdir" -name '*.rej' -print -quit)
+
+    test -z "$reject" || {
+      echo "Rejected hunks left behind in $patchdir: $reject" >&2
+      return 1
+    }
+  }
+
+  apply_patch_if_needed () {
+    patchdir=$1
+    patchlevel=$2
+    patchfile=$3
+
+    if patch --dry-run --batch --forward -d "$patchdir" "-p$patchlevel" \
+         < "$patchfile" >/dev/null 2>&1; then
+      patch --batch --forward -d "$patchdir" "-p$patchlevel" \
+        < "$patchfile" || return $?
+    elif patch --dry-run --batch --forward -R -d "$patchdir" "-p$patchlevel" \
+           < "$patchfile" >/dev/null 2>&1; then
+      echo "Skipping already applied patch: $patchfile"
+    else
+      # Let patch print diagnostics and fail under 'set -e'.
+      patch --batch --forward -d "$patchdir" "-p$patchlevel" \
+        < "$patchfile" || return $?
+    fi
+
+    check_for_rejects "$patchdir" || return $?
+  }
 
   for patchname in \
       0001-Support-POTFILES-shell \
       0002-Handle-gettext_printf-shell-function \
       0003-Make-msgfmt-output-in-little-endian \
       0004-Use-SHELL-rather-than-bin-sh; do
-    patch -d po -p3 \
-      < "po/gettext-patches/$patchname.patch"
+    apply_patch_if_needed po 3 \
+      "po/gettext-patches/$patchname.patch" || return $?
   done
   FROM_BOOTSTRAP=1 ./autogen.sh
   set +e  # bootstrap expects this
