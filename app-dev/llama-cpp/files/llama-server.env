# /etc/llama-server/llama-server.env
# Prefer upstream llama.cpp env vars so systemd can launch llama-server directly
# without shell argument assembly.

# model source
LLAMA_ARG_HF_REPO=unsloth/Qwen3.6-27B-MTP-GGUF:UD-Q2_K_XL
# Alternative local model example:
# LLAMA_ARG_MODEL=/opt/llm-models/model.gguf

# bind
LLAMA_ARG_HOST=0.0.0.0
LLAMA_ARG_PORT=8080

# runtime
LLAMA_ARG_THREADS=16
LLAMA_ARG_CTX_SIZE=20000
LLAMA_ARG_N_GPU_LAYERS=auto
LLAMA_ARG_FIT=on
LLAMA_ARG_FIT_TARGET=1024
LLAMA_ARG_N_PARALLEL=1
LLAMA_ARG_FLASH_ATTN=on
LLAMA_ARG_REASONING=off
LLAMA_ARG_SPEC_TYPE=draft-mtp
LLAMA_ARG_SPEC_DRAFT_N_MAX=3

# model behavior
LLAMA_ARG_MMPROJ_AUTO=off

# batching and kv
LLAMA_ARG_JINJA=on
LLAMA_ARG_MLOCK=on
LLAMA_ARG_KV_OFFLOAD=off
LLAMA_ARG_CACHE_TYPE_K=q8_0
LLAMA_ARG_CACHE_TYPE_V=q8_0
LLAMA_ARG_TOP_K=20

# Flags without upstream env bindings yet. systemd expands this without a shell.
LLAMA_SERVER_EXTRA_ARGS=--temp 0.7 --top-p 0.8 --min-p 0 --presence-penalty 1.5

# cuda and logging
GGML_CUDA_FORCE_MMQ=1
LLAMA_LOG_COLORS=1
