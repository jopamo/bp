#!/bin/bash

set -euo pipefail

log() {
	echo "[efixperm] $*" >&2
}

path_exists() {
	local path=${1}
	[[ -e ${path} || -L ${path} ]]
}

user_exists() {
	getent passwd "${1}" >/dev/null 2>&1
}

group_exists() {
	getent group "${1}" >/dev/null 2>&1
}

owner_spec_valid() {
	local spec=${1}
	local user=${spec%%:*}
	local group=

	if [[ ${spec} == *:* ]]; then
		group=${spec#*:}
	fi

	user_exists "${user}" || return 1
	if [[ -n ${group} ]]; then
		group_exists "${group}" || return 1
	fi
	return 0
}

safe_chmod() {
	local mode=${1}
	shift || true
	local path
	for path in "$@"; do
		path_exists "${path}" || continue
		chmod "${mode}" "${path}"
	done
}

safe_chown() {
	local spec=${1}
	shift || true
	local path
	if ! owner_spec_valid "${spec}"; then
		log "skipping chown to ${spec}: missing user or group"
		return 0
	fi
	for path in "$@"; do
		path_exists "${path}" || continue
		chown "${spec}" "${path}"
	done
}

safe_chown_recursive() {
	local spec=${1}
	shift || true
	local path
	if ! owner_spec_valid "${spec}"; then
		log "skipping recursive chown to ${spec}: missing user or group"
		return 0
	fi
	for path in "$@"; do
		path_exists "${path}" || continue
		chown -hR "${spec}" "${path}"
	done
}

safe_find_chmod() {
	local root=${1}
	local dir_mode=${2}
	local file_mode=${3}
	[[ -d ${root} ]] || return 0
	find "${root}" -type d -exec chmod "${dir_mode}" {} +
	find "${root}" -type f -exec chmod "${file_mode}" {} +
}

cache_owner_spec() {
	if owner_spec_valid corepkg:corepkg; then
		printf 'corepkg:corepkg\n'
		return 0
	fi
	if owner_spec_valid portage:portage; then
		printf 'portage:portage\n'
		return 0
	fi
	return 1
}

if [[ $(id -u) == 0 ]]; then
	shopt -s nullglob

	mkdir -p /var/db/repos /var/cache/distfiles /var/cache/packages
	if cache_owner=$(cache_owner_spec); then
		safe_chown_recursive "${cache_owner}" /var/cache/distfiles /var/cache/packages
	else
		log "skipping cache ownership repair: neither corepkg nor portage account exists"
	fi

	safe_find_chmod /var/db/repos 755 644
	safe_find_chmod /srv/http 755 644
	safe_find_chmod /var/lighttpd 755 644

	safe_chmod 600 /etc/gshadow /etc/shadow
	safe_chmod 644 /etc/group /etc/passwd

	if [[ -d /etc/ssh ]]; then
		safe_chmod 755 /etc/ssh
		safe_chown root:root /etc/ssh
		safe_chmod 644 /etc/ssh/sshd_config /etc/ssh/ssh_config
		for keyfile in /etc/ssh/ssh_host_*_key; do
			safe_chmod 600 "${keyfile}"
			safe_chown root:root "${keyfile}"
		done
		for pubfile in /etc/ssh/ssh_host_*_key.pub; do
			safe_chmod 644 "${pubfile}"
			safe_chown root:root "${pubfile}"
		done
	fi

	safe_chmod 440 /etc/sudoers
	safe_chmod 700 /etc/ssl/private
	for cert in /etc/ssl/certs/*; do
		safe_chmod 644 "${cert}"
	done
	safe_chmod 755 /var/log
	if [[ -d /var/log ]]; then
		find /var/log -type f -exec chmod 640 {} +
	fi
	safe_chmod 1777 /tmp /var/tmp
	safe_chmod 755 /var/spool /var/lib

	safe_chown_recursive tss:tss /var/lib/tpm2-tss

	shopt -u nullglob
fi

if [[ -f ${HOME}/.bash_history ]]; then
	chmod 600 "${HOME}/.bash_history"
fi

if [[ -d ${HOME}/.ssh ]]; then
	find "${HOME}/.ssh" -type d -exec chmod 700 {} +
	find "${HOME}/.ssh" -type f -exec chmod 600 {} +
fi

if [[ -d ${HOME}/.gnupg ]]; then
	find "${HOME}/.gnupg" -type d -exec chmod 700 {} +
	find "${HOME}/.gnupg" -type f -exec chmod 600 {} +
fi
