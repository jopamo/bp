+//go:build nofido
+
+package grpc
+
+import (
+	"context"
+
+	"google.golang.org/protobuf/types/known/emptypb"
+)
+
+func (s *Service) LoginFido(_ context.Context, login *LoginRequest) (*emptypb.Empty, error) {
+	s.log.WithField("username", login.Username).Warn("LoginFido requested but FIDO support is disabled in this build")
+	_ = s.SendEvent(NewLoginError(LoginErrorType_FIDO_ERROR, "Security key authentication is disabled in this build"))
+	s.loginClean()
+	return &emptypb.Empty{}, nil
+}
