+				   snap->adj_limit, snap->avail);
+}
+
+void netdev_txq_trace_reset(
+	struct netdev_queue *txq, unsigned long caller,
+	unsigned long state_before, unsigned long state_after,
+	const struct netdev_txq_trace_dql_snapshot *before,
+	const struct netdev_txq_trace_dql_snapshot *after)
+{
+	trace_net_dev_txq_reset(txq, netdev_txq_trace_index(txq), caller, true,
