From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
Date: Wed, 6 May 2026 09:21:00 -0500
Subject: [PATCH] musl: guard gshadow usage when the header is missing

Musl does not ship <gshadow.h>. Systemd already disables gshadow support for
musl at the meson level, but this snapshot still includes the header
unconditionally from user-util.h. Treat gshadow support as unavailable when
the header itself is missing.
---
 src/basic/user-util.h | 8 +++++++-
 1 file changed, 7 insertions(+), 1 deletion(-)

diff --git a/src/basic/user-util.h b/src/basic/user-util.h
index 275e6ca6b2..9bbdc825d7 100644
--- a/src/basic/user-util.h
+++ b/src/basic/user-util.h
@@ -2,9 +2,15 @@
 #pragma once
 
 #include <grp.h>
-#if ENABLE_GSHADOW
+#if ENABLE_GSHADOW && __has_include(<gshadow.h>)
 #  include <gshadow.h>
+#  define GSHADOW_HEADER_AVAILABLE 1
+#else
+#  define GSHADOW_HEADER_AVAILABLE 0
 #endif
+
+#undef ENABLE_GSHADOW
+#define ENABLE_GSHADOW GSHADOW_HEADER_AVAILABLE
 #include <pwd.h>
 #include <shadow.h>
 
-- 
2.49.0
