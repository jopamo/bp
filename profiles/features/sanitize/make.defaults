GRAPHITE_FLAGS=""
LTO_FLAGS=""
SAN_FLAGS="-fsanitize=address,undefined"

FEATURES="${FEATURES} nostrip"

CFLAGS="${MARCH} -O1 -g ${POSITION_FLAGS} ${SECURITY_FLAGS} ${SAN_FLAGS} -fno-omit-frame-pointer ${REPRO_FLAGS}"
CXXFLAGS="${CFLAGS}"
CPPFLAGS="${CFLAGS}"
FFLAGS="${CFLAGS}"
FCFLAGS="${CFLAGS}"
LDFLAGS="${POSITION_FLAGS} ${SAN_FLAGS} \
    -Wl,-O1 \
    -Wl,-z,relro -Wl,-z,now -Wl,--as-needed"
