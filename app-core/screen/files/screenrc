activity "activity in %n"
altscreen on
attrcolor b ".I"
autodetach on
defbce on
defc1 off
defencoding utf8
defflow off
defhstatus "screen ^E (^Et) | $USER@^EH"
defmonitor on
defnonblock 1
defscrollback 100000
defutf8 on
hardstatus off
ignorecase on
msgwait 3
nethack off
startup_message off
vbell off
vbell_msg ""
setenv DISPLAY ':0'
shell -${SHELL}
shelltitle "$ |bash"
term screen-256color
truecolor on
termcapinfo xterm* 'hs:ts=\E]0;:fs=\007:ds=\E]0;\007'
termcapinfo xterm* ti@:te@
mousetrack off
termcapinfo * Km@
termcapinfo * XM@
