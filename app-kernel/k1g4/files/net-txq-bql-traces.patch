 void netif_schedule_queue(struct netdev_queue *txq)
 {
+	bool trace = netdev_txq_trace_enabled();
+	unsigned long state_before = 0;
+	struct netdev_txq_trace_dql_snapshot snap;
+	bool did_schedule = false;
+
+	if (trace) {
+		state_before = READ_ONCE(txq->state);
+		netdev_txq_trace_snapshot_dql(txq, &snap);
+	}
+
 	rcu_read_lock();
 	if (!netif_xmit_stopped(txq)) {
 		struct Qdisc *q = rcu_dereference(txq->qdisc);
 
 		__netif_schedule(q);
+		did_schedule = true;
 	}
 	rcu_read_unlock();
+
+	if (trace)
+		netdev_txq_trace_schedule(
+			txq, (unsigned long)__builtin_return_address(0),
+			did_schedule, state_before, READ_ONCE(txq->state),
+			&snap);
 }
 EXPORT_SYMBOL(netif_schedule_queue);
 
 void netif_tx_wake_queue(struct netdev_queue *dev_queue)
 {
+	bool trace = netdev_txq_trace_enabled();
+	unsigned long state_before = 0;
+	struct netdev_txq_trace_dql_snapshot snap;
+	bool did_wake = false;
+
+	if (trace) {
+		state_before = READ_ONCE(dev_queue->state);
+		netdev_txq_trace_snapshot_dql(dev_queue, &snap);
+	}
+
 	if (test_and_clear_bit(__QUEUE_STATE_DRV_XOFF, &dev_queue->state)) {
 		struct Qdisc *q;
 
@@ -3436,7 +3463,14 @@ void netif_tx_wake_queue(struct netdev_queue *dev_queue)
 		q = rcu_dereference(dev_queue->qdisc);
 		__netif_schedule(q);
 		rcu_read_unlock();
+		did_wake = true;
 	}
+
+	if (trace)
+		netdev_txq_trace_wake(
+			dev_queue, (unsigned long)__builtin_return_address(0),
+			did_wake, state_before, READ_ONCE(dev_queue->state),
+			&snap);
 }
 EXPORT_SYMBOL(netif_tx_wake_queue);
 
