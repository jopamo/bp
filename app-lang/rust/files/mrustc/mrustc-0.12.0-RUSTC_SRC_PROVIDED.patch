@@ -303,22 +324,22 @@
 LLVM_CMAKE_OPTS += $(LLVM_CMAKE_OPTS_EXTRA)
 
 
-$(RUSTCSRC)build/bin/llvm-config: $(RUSTCSRC)build/Makefile
-	$Vcd $(RUSTCSRC)build && $(MAKE) -j $(PARLEVEL)
+$(RUSTCSRC)/build/bin/llvm-config: $(RUSTCSRC)/build/Makefile
