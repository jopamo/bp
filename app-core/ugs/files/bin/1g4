#!/usr/bin/env python3
import re
import sys
import os

def process_filename(filename):
    """
    Process the filename according to the versioning rules:
    - Simple versioning: process normally
    - Date-based, revision, commit, pre-release, and patch versions: ignore or replace as needed.
    """

    # Pattern 1: Simple versioning (e.g., "autoconf-2.72.ebuild")
    simple_version_pattern = r'(\d+\.\d+)(?=\.[^\.]+$)'

    # Pattern 2: Date-based versioning (e.g., "binutils-2.43.20250223.ebuild")
    date_version_pattern = r'(\d+\.\d+\.\d{4}\.\d{2}\.\d{2})(?=\.[^\.]+$)'

    # Pattern 3: Revision-based versioning (e.g., "flex-20250114-r9.ebuild")
    revision_version_pattern = r'(\d{8})(-r\d+)?(?=\.[^\.]+$)'

    # Pattern 4: Rolling release versions (e.g., "keepassxc-9999.ebuild")
    rolling_version_pattern = r'(\d{4})\.9999(?=\.[^\.]+$)'

    # Pattern 5: Pre-release versions (e.g., "python-exec-20230320.ebuild")
    prerelease_version_pattern = r'(\d{4}\d{2}\d{2})(?=\.[^\.]+$)'

    # Pattern 6: Patch versioning (e.g., "unzip-6.0_p28.ebuild")
    patch_version_pattern = r'(\d+\.\d+)_p(\d+)(?=\.[^\.]+$)'

    # Pattern 7: Fixed versioning (e.g., "protobuf-30.0.ebuild")
    fixed_version_pattern = r'(\d+\.\d+)(?=\.[^\.]+$)'

    # Ignore Date-based versions
    if re.search(date_version_pattern, filename):
        print(f"Ignoring date-based version: {filename}")
        return None

    # Ignore Revision-based versions
    if re.search(revision_version_pattern, filename):
        print(f"Ignoring revision-based version: {filename}")
        return None

    # Ignore Rolling releases
    if re.search(rolling_version_pattern, filename):
        print(f"Ignoring rolling release version: {filename}")
        return None

    # Ignore Pre-release versions
    if re.search(prerelease_version_pattern, filename):
        print(f"Ignoring pre-release version: {filename}")
        return None

    # Ignore Patch versions
    if re.search(patch_version_pattern, filename):
        print(f"Ignoring patch version: {filename}")
        return None

    # For Simple versioning, process normally
    if re.search(simple_version_pattern, filename):
        print(f"Processing simple version: {filename}")
        return filename  # Return as is for simple versioning

    # Fixed version should be treated as simple versioning
    if re.search(fixed_version_pattern, filename):
        print(f"Processing fixed version (treated as simple version): {filename}")
        return filename  # Treat as simple versioning

    # If no match, we just ignore
    print(f"Ignoring unknown version format: {filename}")
    return None

def run_tests():
    """
    Run tests on a predefined list of sample filenames
    """
    filenames = [
        "autoconf-2.72.ebuild",
        "binutils-2.43.20250223.ebuild",  # This should be ignored
        "flex-20250114-r9.ebuild",        # This should be ignored
        "keepassxc-9999.ebuild",          # This should be ignored
        "python-exec-20230320.ebuild",    # This should be ignored
        "unzip-6.0_p28.ebuild",           # This should be ignored
        "protobuf-30.0.ebuild",
        "codeql-20250222.ebuild",
        "cargo-c-20250222.ebuild",
        "xkeyboard-config-2.40.ebuild",
        "pipewire-1.0.3.ebuild",
        "swaylock-20250320.ebuild",
        "gcc-13.3.20250325.ebuild",
        "curl-20250412.ebuild"
    ]

    # Process all filenames
    for filename in filenames:
        processed_filename = process_filename(filename)
        if processed_filename:
            print(f"Processed: {processed_filename}")
        else:
            print(f"File ignored.")

def build_report():
    """
    Build the report by processing files in the current working directory
    """
    for root, dirs, files in os.walk(os.getcwd()):
        for file in files:
            if file.endswith('.ebuild'):
                print(f"Processing: {file}")
                process_filename(file)

if __name__ == "__main__":
    if '--test' in sys.argv:
        # Run tests if --test argument is passed
        run_tests()
    else:
        # Otherwise, build the report
        print("Building report...")
        build_report()
