#!/bin/bash

set -euo pipefail

usage() {
	cat <<-'USAGE'
	Usage:
	  1g4-finalize-install ROOT [options]

	Finalize a mounted target root as an installed, boot-ready system.
	This is the one-shot wrapper around 1g4-system-setup.

	Options:
	  --hostname NAME              default: 1g4
	  --user NAME                  default: current non-root login user
	  --user-shell PATH            default: /usr/bin/bash
	  --groups CSV                 default: wheel,audio,video,input
	  --locale LOCALE              default: C.UTF-8
	  --keymap KEYMAP              default: us
	  --timezone ZONE              default: host timezone or UTC
	  --network-match GLOBS        default: host0 en* eth*
	  --network-dns "IP ..."       optional DNS for generated networkd config
	  --no-network                 do not generate installer-owned networkd config
	  --kernel-extra STRING        default: quiet
	  --bootloader auto|grub|none  default: auto
	  --grub-device DEV            explicit BIOS/MBR grub-install target
	  --grub-target TARGET         explicit grub --target
	  --grub-boot-id ID            default: 1g4
	  --root-password-hash HASH    use explicit root password hash
	  --user-password-hash HASH    use explicit user password hash
	  --yes                        accept defaults without prompts
	  -h, --help                   show this help
	USAGE
}

die() {
	echo "$(basename "$0"): $*" >&2
	exit 1
}

log() {
	echo "[$(basename "$0")] $*"
}

require_command() {
	command -v "$1" >/dev/null 2>&1 || die "$1 is required"
}

root_path() {
	local rel=${1-}
	[[ $# -ge 1 ]] || die "root_path requires a path"
	if [[ ${ROOT} == / ]]; then
		printf '/%s\n' "${rel#/}"
	else
		printf '%s/%s\n' "${ROOT}" "${rel#/}"
	fi
}

root_relative_path() {
	local abs=${1-}
	[[ $# -ge 1 ]] || die "root_relative_path requires a path"
	if [[ ${ROOT} == / ]]; then
		printf '/%s\n' "${abs#/}"
	else
		printf '/%s\n' "${abs#"${ROOT}/"}"
	fi
}

target_hint_path() {
	local rel=${1-}
	[[ $# -ge 1 ]] || die "target_hint_path requires a path"
	if [[ ${ROOT} == / ]]; then
		printf '%s\n' "${rel}"
	else
		printf '%s%s\n' "${ROOT}" "${rel}"
	fi
}

default_timezone() {
	local tz
	if [[ -r /etc/timezone ]]; then
		read -r tz < /etc/timezone || true
		[[ -n ${tz:-} ]] && {
			printf '%s\n' "${tz}"
			return 0
		}
	fi
	if [[ -L /etc/localtime ]]; then
		tz=$(readlink /etc/localtime || true)
		case ${tz} in
			*/usr/share/zoneinfo/*)
				printf '%s\n' "${tz##*/usr/share/zoneinfo/}"
				return 0
				;;
		esac
	fi
	printf 'UTC\n'
}

resolve_target_timezone() {
	local timezone=${1-}
	local zoneinfo_root candidate
	[[ -n ${timezone} ]] || return 1
	case ${timezone} in
		/*|*'..'*)
			return 1
			;;
	esac
	zoneinfo_root=$(root_path /usr/share/zoneinfo)
	[[ -d ${zoneinfo_root} ]] || die "target is missing /usr/share/zoneinfo; install lib-core/tzdb before running $(basename "$0")"
	for candidate in "${timezone}" "Etc/${timezone}"; do
		[[ -e ${zoneinfo_root}/${candidate} ]] || continue
		printf '%s\n' "${candidate}"
		return 0
	done
	return 1
}

normalize_target_timezone() {
	local timezone=${1-}
	local resolved
	[[ -n ${timezone} ]] || die "timezone must not be empty"
	resolved=$(resolve_target_timezone "${timezone}" || true)
	[[ -n ${resolved} ]] || die "timezone data is missing for ${timezone} under $(target_hint_path /usr/share/zoneinfo); install lib-core/tzdb or choose an available zone"
	printf '%s\n' "${resolved}"
}

default_login_user() {
	local candidate=${SUDO_USER:-${USER:-}}
	case ${candidate} in
		''|root) return 1 ;;
		*) printf '%s\n' "${candidate}" ;;
	esac
}

prompt_default() {
	local label=${1}
	local default_value=${2:-}
	local reply
	if [[ -n ${default_value} ]]; then
		read -r -p "${label} [${default_value}]: " reply || true
		printf '%s\n' "${reply:-${default_value}}"
	else
		read -r -p "${label}: " reply || true
		printf '%s\n' "${reply}"
	fi
}

hash_password() {
	local password=${1}
	if command -v openssl >/dev/null 2>&1; then
		printf '%s\n' "${password}" | openssl passwd -6 -stdin
		return 0
	fi
	die "cannot hash passwords without openssl"
}

prompt_password_hash() {
	local label=${1}
	local pw1 pw2
	while :; do
		read -r -s -p "${label} (leave blank to skip): " pw1 || true
		echo
		if [[ -z ${pw1} ]]; then
			printf '\n'
			return 0
		fi
		read -r -s -p "Confirm ${label}: " pw2 || true
		echo
		[[ ${pw1} == ${pw2} ]] || {
			echo "Passwords did not match." >&2
			continue
		}
		hash_password "${pw1}"
		return 0
	done
}

target_has_command() {
	local cmd=${1}
	[[ -x $(root_path "/usr/bin/${cmd}") ]] || \
	[[ -x $(root_path "/usr/sbin/${cmd}") ]] || \
	[[ -x $(root_path "/bin/${cmd}") ]] || \
	[[ -x $(root_path "/sbin/${cmd}") ]]
}

target_command_path() {
	local cmd=${1}
	local candidate
	for candidate in \
		"/usr/bin/${cmd}" \
		"/usr/sbin/${cmd}" \
		"/bin/${cmd}" \
		"/sbin/${cmd}"
	do
		[[ -x $(root_path "${candidate}") ]] || continue
		printf '%s\n' "${candidate}"
		return 0
	done
	return 1
}

is_pseudo_fstype() {
	case ${1} in
		autofs|bpf|cgroup|cgroup2|configfs|debugfs|devpts|devtmpfs|efivarfs|fusectl|hugetlbfs|mqueue|nsfs|overlay|proc|pstore|ramfs|securityfs|squashfs|sysfs|tmpfs|tracefs)
			return 0
			;;
		*)
			return 1
			;;
	esac
}

mount_rel_path() {
	local target=${1}
	if [[ ${target} == ${ROOT} ]]; then
		printf '/\n'
	elif [[ ${ROOT} == / ]]; then
		printf '%s\n' "${target}"
	else
		printf '/%s\n' "${target#"${ROOT}/"}"
	fi
}

fs_spec_from_fields() {
	local source=${1}
	local uuid=${2}
	local partuuid=${3}
	if [[ -n ${uuid} && ${uuid} != '-' ]]; then
		printf 'UUID=%s\n' "${uuid}"
	elif [[ -n ${partuuid} && ${partuuid} != '-' ]]; then
		printf 'PARTUUID=%s\n' "${partuuid}"
	else
		printf '%s\n' "${source}"
	fi
}

mount_requires_fstab_entry() {
	local rel=${1}
	local fstype=${2}
	case ${rel} in
		/dev|/dev/*|/proc|/proc/*|/run|/run/*|/sys|/sys/*)
			return 1
			;;
	esac
	is_pseudo_fstype "${fstype}" && return 1
	return 0
}

ensure_stable_fs_spec() {
	local rel=${1}
	local source=${2}
	local spec=${3}
	case ${source} in
		/dev/*)
			case ${spec} in
				UUID=*|PARTUUID=*) return 0 ;;
			esac
			die "cannot generate a stable fstab entry for ${rel}: ${source} has no UUID/PARTUUID"
			;;
	esac
}

mount_has_option() {
	local options=${1}
	local needle=${2}
	case ",${options}," in
		*",${needle},"*) return 0 ;;
		*) return 1 ;;
	esac
}

mount_is_bind() {
	local options=${1}
	mount_has_option "${options}" bind || mount_has_option "${options}" rbind
}

passno_for_mount() {
	local rel=${1}
	local fstype=${2}
	local options=${3:-}
	if mount_is_bind "${options}"; then
		printf '0\n'
		return 0
	fi
	if [[ ${rel} == / ]]; then
		printf '1\n'
		return 0
	fi
	case ${rel}:${fstype} in
		/boot/efi:*|*/swap:swap|*:swap)
			printf '0\n'
			;;
		*)
			printf '2\n'
			;;
	esac
}

normalize_fstab_options() {
	local rel=${1}
	local fstype=${2}
	local options=${3}
	local opt
	local -a normalized=()
	local saw_ro=no

	if mount_is_bind "${options}"; then
		IFS=, read -r -a _raw_opts <<< "${options}"
		for opt in "${_raw_opts[@]}"; do
			case ${opt} in
				''|rw|relatime)
					continue
					;;
				*)
					normalized+=("${opt}")
					;;
			esac
		done
		if (( ${#normalized[@]} == 0 )); then
			printf 'bind\n'
			return 0
		fi
		printf '%s' "${normalized[0]}"
		for opt in "${normalized[@]:1}"; do
			printf ',%s' "${opt}"
		done
		printf '\n'
		return 0
	fi

	IFS=, read -r -a _raw_opts <<< "${options}"
	for opt in "${_raw_opts[@]}"; do
		case ${opt} in
			''|rw|relatime)
				continue
				;;
			ro)
				saw_ro=yes
				;;
			*)
				normalized+=("${opt}")
				;;
		esac
	done

	if [[ ${saw_ro} == yes ]]; then
		printf 'ro'
	else
		printf 'defaults'
	fi

	for opt in "${normalized[@]}"; do
		printf ',%s' "${opt}"
	done
	printf '\n'
}

collect_mount_table() {
	local raw
	raw=$(mktemp)
	findmnt -R -rno TARGET,SOURCE,FSTYPE,OPTIONS,UUID,PARTUUID --target "${ROOT}" > "${raw}" || die "failed to inspect mounted filesystems under ${ROOT}"
	[[ -s ${raw} ]] || die "no mounted filesystems found under ${ROOT}"
	if [[ ${ROOT} == / ]]; then
		awk '{ print length($1), $0 }' "${raw}" |
			sort -n -k1,1 |
			cut -d' ' -f2- > "${MOUNT_TABLE}"
	else
		awk -v root="${ROOT}" '$1 == root || index($1, root "/") == 1 { print }' "${raw}" |
			awk '{ print length($1), $0 }' |
			sort -n -k1,1 |
			cut -d' ' -f2- > "${MOUNT_TABLE}"
	fi
	rm -f "${raw}"
	[[ -s ${MOUNT_TABLE} ]] || die "could not build mount table for ${ROOT}"
	awk -v root="${ROOT}" '$1 == root { found=1 } END { exit(found ? 0 : 1) }' "${MOUNT_TABLE}" || die "${ROOT} itself is not mounted"
}

preserve_existing_bind_mounts() {
	local existing line_count=0
	existing=$(root_path /etc/fstab)
	[[ -f ${existing} ]] || return 0
	while IFS= read -r line; do
		PRESERVED_BIND_LINES+=("${line}")
		line_count=$((line_count + 1))
	done < <(
		awk '
			/^[[:space:]]*#/ || NF < 4 { next }
			{
				n = split($4, opts, ",")
				for (i = 1; i <= n; ++i) {
					if (opts[i] == "bind" || opts[i] == "rbind") {
						print
						next
					}
				}
			}
		' "${existing}"
	)
	(( line_count > 0 )) || return 0
}

append_preserved_bind_mounts() {
	local line
	(( ${#PRESERVED_BIND_LINES[@]} > 0 )) || return 0
	{
		printf '\n'
		printf '# Preserved bind mounts from existing /etc/fstab.\n'
		for line in "${PRESERVED_BIND_LINES[@]}"; do
			printf '%s\n' "${line}"
		done
	} >> "${FSTAB_FILE}"
}

discover_crypt_ancestors() {
	local source=${1}
	local device info name type pkname backing luks_type luks_uuid
	[[ ${source} == /dev/* ]] || return 0
	device=$(readlink -f "${source}" 2>/dev/null || printf '%s\n' "${source}")
	while [[ -n ${device} && ${device} == /dev/* ]]; do
		info=$(lsblk -ndo NAME,TYPE,PKNAME "${device}" 2>/dev/null | head -n1 || true)
		[[ -n ${info} ]] || break
		read -r name type pkname <<< "${info}"
		if [[ ${type} == crypt && -z ${CRYPT_UUID_BY_NAME[${name}]:-} ]]; then
			backing=
			if command -v cryptsetup >/dev/null 2>&1; then
				backing=$(cryptsetup status "${name}" 2>/dev/null | awk '/^[[:space:]]*device:[[:space:]]*/ { print $2; exit }' || true)
			fi
			if [[ -n ${backing} ]]; then
				luks_type=$(blkid -s TYPE -o value "${backing}" 2>/dev/null || true)
				if [[ ${luks_type} == crypto_LUKS ]]; then
					luks_uuid=$(blkid -s UUID -o value "${backing}" 2>/dev/null || true)
					[[ -n ${luks_uuid} ]] || die "found LUKS device ${backing} for ${name} but could not read its UUID"
					CRYPT_UUID_BY_NAME[${name}]=${luks_uuid}
					CRYPT_ORDER+=("${name}")
				fi
			fi
		fi
		[[ -n ${pkname:-} ]] || break
		device=/dev/${pkname}
	done
}

generate_fstab() {
	local target source fstype options uuid partuuid rel spec passno fstab_options entry_source entry_type line_count=0
	: > "${FSTAB_FILE}"
	while read -r target source fstype options uuid partuuid; do
		rel=$(mount_rel_path "${target}")
		mount_requires_fstab_entry "${rel}" "${fstype}" || continue
		mount_is_bind "${options}" && continue
		spec=$(fs_spec_from_fields "${source}" "${uuid:-}" "${partuuid:-}")
		ensure_stable_fs_spec "${rel}" "${source}" "${spec}"
		entry_source=${spec}
		entry_type=${fstype}
		passno=$(passno_for_mount "${rel}" "${fstype}" "${options}")
		fstab_options=$(normalize_fstab_options "${rel}" "${fstype}" "${options}")
		printf '%s %s %s %s 0 %s\n' "${entry_source}" "${rel}" "${entry_type}" "${fstab_options}" "${passno}" >> "${FSTAB_FILE}"
		line_count=$((line_count + 1))
		discover_crypt_ancestors "${source}"
	done < "${MOUNT_TABLE}"
	append_preserved_bind_mounts
	(( line_count > 0 )) || die "failed to generate /etc/fstab contents"
}

validate_generated_fstab() {
	local target source fstype options uuid partuuid rel spec entry_source entry_type
	while read -r target source fstype options uuid partuuid; do
		rel=$(mount_rel_path "${target}")
		mount_requires_fstab_entry "${rel}" "${fstype}" || continue
		mount_is_bind "${options}" && continue
		spec=$(fs_spec_from_fields "${source}" "${uuid:-}" "${partuuid:-}")
		entry_source=${spec}
		entry_type=${fstype}
		grep -qE "^[^[:space:]]+[[:space:]]+${rel//\//\\/}[[:space:]]+${entry_type//\//\\/}[[:space:]]" "${FSTAB_FILE}" || \
			die "generated fstab is missing an entry for ${rel} (${entry_type})"
		grep -qE "^${entry_source//\//\\/}[[:space:]]+${rel//\//\\/}[[:space:]]+${entry_type//\//\\/}[[:space:]]" "${FSTAB_FILE}" || \
			die "generated fstab entry for ${rel} does not use the detected source ${entry_source}"
	done < "${MOUNT_TABLE}"
}

write_crypttab() {
	local name
	: > "${CRYPTTAB_FILE}"
	if (( ${#CRYPT_ORDER[@]} == 0 )); then
		LUKS_USED=no
		return 0
	fi
	for name in "${CRYPT_ORDER[@]}"; do
		printf '%s UUID=%s none luks\n' "${name}" "${CRYPT_UUID_BY_NAME[${name}]}" >> "${CRYPTTAB_FILE}"
	done
	LUKS_USED=yes
}

build_kernel_cmdline() {
	local target source fstype options uuid partuuid rel root_spec name extras
	while read -r target source fstype options uuid partuuid; do
		rel=$(mount_rel_path "${target}")
		[[ ${rel} == / ]] || continue
		root_spec=$(fs_spec_from_fields "${source}" "${uuid:-}" "${partuuid:-}")
		break
	done < "${MOUNT_TABLE}"
	[[ -n ${root_spec:-} ]] || die "could not determine root filesystem spec"
	KERNEL_CMDLINE="root=${root_spec} rw"
	for name in "${CRYPT_ORDER[@]}"; do
		KERNEL_CMDLINE+=" rd.luks.name=${CRYPT_UUID_BY_NAME[${name}]}=${name}"
	done
	if [[ -n ${KERNEL_EXTRA} ]]; then
		KERNEL_CMDLINE+=" ${KERNEL_EXTRA}"
	fi
}

detect_kernel_installation() {
	local image modules_dir
	KERNEL_IMAGE=
	KERNEL_MODULE_TREE=
	KERNEL_MODULE_RELEASE=

	if [[ -d $(root_path /boot) ]]; then
		image=$(find "$(root_path /boot)" -maxdepth 1 -type f \( -name 'vmlinuz*' -o -name 'kernel*' -o -name 'bzImage*' \) -print -quit 2>/dev/null || true)
		if [[ -n ${image} ]]; then
			KERNEL_IMAGE=$(root_relative_path "${image}")
		fi
	fi

	if [[ -d $(root_path /usr/lib/modules) ]]; then
		modules_dir=$(find "$(root_path /usr/lib/modules)" -mindepth 1 -maxdepth 1 -type d -print -quit 2>/dev/null || true)
	fi
	if [[ -z ${modules_dir:-} && -d $(root_path /lib/modules) ]]; then
		modules_dir=$(find "$(root_path /lib/modules)" -mindepth 1 -maxdepth 1 -type d -print -quit 2>/dev/null || true)
	fi
	if [[ -n ${modules_dir:-} ]]; then
		KERNEL_MODULE_TREE=$(root_relative_path "${modules_dir}")
		KERNEL_MODULE_RELEASE=${modules_dir##*/}
	fi

	if [[ -z ${KERNEL_IMAGE} && -z ${KERNEL_MODULE_TREE} ]]; then
		die "no compiled/installed kernel detected under ${ROOT}: missing a kernel image in /boot and a kernel module tree in /usr/lib/modules or /lib/modules. Build/install a kernel before running $(basename "$0")."
	fi
	if [[ -z ${KERNEL_IMAGE} ]]; then
		die "incomplete kernel install under ${ROOT}: kernel module tree ${KERNEL_MODULE_TREE} exists, but no kernel image was found in /boot. Install the kernel to /boot before running $(basename "$0")."
	fi
	if [[ -z ${KERNEL_MODULE_TREE} ]]; then
		die "incomplete kernel install under ${ROOT}: kernel image ${KERNEL_IMAGE} exists, but no kernel module tree was found in /usr/lib/modules or /lib/modules. Install the kernel modules before running $(basename "$0")."
	fi
}

detect_bios_grub_target() {
	local target source fstype options uuid partuuid rel candidate info type pkname

	candidate=
	while read -r target source fstype options uuid partuuid; do
		rel=$(mount_rel_path "${target}")
		case ${rel} in
			/boot)
				mount_requires_fstab_entry "${rel}" "${fstype}" || continue
				mount_is_bind "${options}" && continue
				candidate=${source}
				break
				;;
		esac
	done < "${MOUNT_TABLE}"

	if [[ -z ${candidate} ]]; then
		while read -r target source fstype options uuid partuuid; do
			rel=$(mount_rel_path "${target}")
			case ${rel} in
				/)
					mount_requires_fstab_entry "${rel}" "${fstype}" || continue
					mount_is_bind "${options}" && continue
					candidate=${source}
					break
					;;
			esac
		done < "${MOUNT_TABLE}"
	fi

	[[ -n ${candidate} && ${candidate} == /dev/* ]] || return 1
	info=$(lsblk -ndo TYPE,PKNAME "${candidate}" 2>/dev/null | head -n1 || true)
	[[ -n ${info} ]] || return 1
	read -r type pkname <<< "${info}"
	case ${type} in
		part)
			[[ -n ${pkname:-} ]] || return 1
			printf '/dev/%s\n' "${pkname}"
			return 0
			;;
		disk)
			printf '%s\n' "${candidate}"
			return 0
			;;
	esac
	return 1
}

detect_efi_directory() {
	local target source fstype options uuid partuuid rel
	while read -r target source fstype options uuid partuuid; do
		rel=$(mount_rel_path "${target}")
		case ${rel}:${fstype} in
			/boot/efi:vfat|/boot/efi:msdos|/boot/efi:fat)
				printf '/boot/efi\n'
				return 0
				;;
		esac
	done < "${MOUNT_TABLE}"
	if [[ -d $(root_path /boot/efi/EFI) ]]; then
		printf '/boot/efi\n'
		return 0
	fi
	if [[ -d $(root_path /boot/EFI) ]]; then
		printf '/boot\n'
		return 0
	fi
	return 1
}

detect_existing_bootloader_config() {
	local candidate
	for candidate in \
		/boot/grub.cfg \
		/boot/grub/grub.cfg \
		/boot/grub2/grub.cfg \
		/boot/loader/loader.conf \
		/boot/extlinux/extlinux.conf \
		/boot/syslinux/syslinux.cfg
	do
		if [[ -e $(root_path "${candidate}") ]]; then
			printf '%s\n' "${candidate}"
			return 0
		fi
	done
	if compgen -G "$(root_path '/boot/loader/entries/*.conf')" >/dev/null; then
		printf '__systemd_entries__\n'
		return 0
	fi
	return 1
}

default_grub_target() {
	local candidate
	for candidate in x86_64-efi arm64-efi; do
		[[ -d $(root_path "/usr/lib/grub/${candidate}") ]] && {
			printf '%s\n' "${candidate}"
			return 0
		}
	done
	case $(uname -m) in
		x86_64) printf 'x86_64-efi\n' ;;
		aarch64|arm64) printf 'arm64-efi\n' ;;
		*) die "could not infer a GRUB EFI target for $(uname -m); pass --grub-target" ;;
	esac
}

default_grub_config_path() {
	if [[ -d $(root_path /boot/grub2) ]]; then
		printf '/boot/grub2/grub.cfg\n'
	else
		printf '/boot/grub/grub.cfg\n'
	fi
}

build_target_command() {
	local cmd="" arg
	if [[ ${ROOT} != / ]]; then
		printf -v cmd 'chroot %q ' "${ROOT}"
	fi
	for arg in "$@"; do
		printf -v cmd '%s%q ' "${cmd}" "${arg}"
	done
	printf '%s\n' "${cmd% }"
}

build_target_env_command() {
	local cmd="" arg env_path env_cmd ldconfig_override=
	env_path=/usr/bin:/usr/sbin:/bin:/sbin
	if ! target_has_command ldconfig; then
		ldconfig_override=DRACUT_LDCONFIG=/bin/true
	fi
	if [[ ${ROOT} != / ]]; then
		env_cmd=$(target_command_path env || true)
		[[ -n ${env_cmd} ]] || die "target does not contain env; cannot build hook command"
		printf -v cmd 'chroot %q %q PATH=%q ' "${ROOT}" "${env_cmd}" "${env_path}"
	else
		printf -v cmd 'env PATH=%q ' "${env_path}"
	fi
	if [[ -n ${ldconfig_override} ]]; then
		printf -v cmd '%s%q ' "${cmd}" "${ldconfig_override}"
	fi
	for arg in "$@"; do
		printf -v cmd '%s%q ' "${cmd}" "${arg}"
	done
	printf '%s\n' "${cmd% }"
}

build_boot_hooks() {
	local efi_dir existing_cfg has_boot_entries=no bios_target=
	INITRAMFS_CMD=
	BOOTLOADER_INSTALL_CMD=
	BOOTLOADER_CONFIG_CMD=
	BOOTLOADER_CONFIG=

	target_has_command dracut || die "target does not contain dracut; cannot build initramfs"
	INITRAMFS_CMD=$(build_target_env_command dracut --force --regenerate-all --no-uefi --no-ukify)

	existing_cfg=$(detect_existing_bootloader_config || true)
	if [[ ${existing_cfg} == __systemd_entries__ ]]; then
		has_boot_entries=yes
		existing_cfg=
	fi

	case ${BOOTLOADER} in
		none)
			BOOTLOADER_CONFIG=${existing_cfg:-}
			return 0
			;;
		auto|grub) ;;
		*) die "unsupported bootloader mode: ${BOOTLOADER}" ;;
	esac

	if ! target_has_command grub-install || ! target_has_command grub-mkconfig; then
		if [[ ${BOOTLOADER} == auto && ( -n ${existing_cfg} || ${has_boot_entries} == yes ) ]]; then
			BOOTLOADER_CONFIG=${existing_cfg}
			return 0
		fi
		die "target does not contain grub-install and grub-mkconfig"
	fi

	BOOTLOADER_CONFIG=$(default_grub_config_path)
	BOOTLOADER_CONFIG_CMD=$(build_target_command grub-mkconfig -o "${BOOTLOADER_CONFIG}")

	if [[ -n ${GRUB_DEVICE} ]]; then
		BOOTLOADER_INSTALL_CMD=$(build_target_command grub-install "${GRUB_DEVICE}")
		return 0
	fi

	efi_dir=$(detect_efi_directory || true)
	if [[ -n ${efi_dir} ]]; then
		GRUB_TARGET=${GRUB_TARGET:-$(default_grub_target)}
		BOOTLOADER_INSTALL_CMD=$(build_target_command grub-install "--target=${GRUB_TARGET}" "--efi-directory=${efi_dir}" "--bootloader-id=${GRUB_BOOT_ID}")
		return 0
	fi

	if [[ -d $(root_path /usr/lib/grub/i386-pc) ]]; then
		bios_target=$(detect_bios_grub_target || true)
		if [[ -n ${bios_target} ]]; then
			BOOTLOADER_INSTALL_CMD=$(build_target_command grub-install "${bios_target}")
			return 0
		fi
	fi

	if [[ ${BOOTLOADER} == auto ]]; then
		die "cannot infer a safe grub-install target; mount the EFI system partition at $(target_hint_path /boot) or $(target_hint_path /boot/efi), or pass --grub-device. For legacy BIOS installs, keep /boot or / on a plain disk partition so $(basename "$0") can infer the parent disk."
	fi
	die "grub was requested but no EFI mount or --grub-device was provided"
}

write_config_var() {
	local name=${1}
	local value=${2}
	printf '%s=%q\n' "${name}" "${value}" >> "${CONFIG_FILE}"
}

show_summary() {
	cat <<-EOF2
	Target root:          ${ROOT}
	Hostname:             ${HOSTNAME}
	Normal user:          ${NORMAL_USER}
	User shell:           ${USER_SHELL}
	Groups:               ${SUPPLEMENTARY_GROUPS}
	Locale:               ${LOCALE}
	Keymap:               ${KEYMAP}
	Timezone:             ${TIMEZONE}
	Network config:       $( [[ ${NO_NETWORK} == yes ]] && echo disabled || echo generated-networkd-dhcp )
	LUKS detected:        ${LUKS_USED}
	Kernel image:         ${KERNEL_IMAGE}
	Kernel modules:       ${KERNEL_MODULE_TREE}
	Kernel cmdline:       ${KERNEL_CMDLINE}
	Initramfs hook:       ${INITRAMFS_CMD:-none}
	Bootloader install:   ${BOOTLOADER_INSTALL_CMD:-none}
	Bootloader config:    ${BOOTLOADER_CONFIG_CMD:-${BOOTLOADER_CONFIG:-none}}
	EOF2
	echo "Planned /etc/fstab:"
	sed 's/^/  /' "${FSTAB_FILE}"
}

ROOT=
HOSTNAME=
NORMAL_USER=
USER_SHELL=/usr/bin/bash
SUPPLEMENTARY_GROUPS=wheel,audio,video,input
LOCALE=C.UTF-8
KEYMAP=us
TIMEZONE=
NETWORK_MATCH='host0 en* eth*'
NETWORK_DNS=
NO_NETWORK=no
KERNEL_EXTRA=quiet
BOOTLOADER=auto
GRUB_DEVICE=
GRUB_TARGET=
GRUB_BOOT_ID=1g4
ROOT_PASSWORD_HASH=
USER_PASSWORD_HASH=
YES=no

while [[ $# -gt 0 ]]; do
	case ${1} in
		--hostname)
			[[ $# -ge 2 ]] || die "--hostname requires an argument"
			HOSTNAME=${2}
			shift 2
			;;
		--user)
			[[ $# -ge 2 ]] || die "--user requires an argument"
			NORMAL_USER=${2}
			shift 2
			;;
		--user-shell)
			[[ $# -ge 2 ]] || die "--user-shell requires an argument"
			USER_SHELL=${2}
			shift 2
			;;
		--groups)
			[[ $# -ge 2 ]] || die "--groups requires an argument"
			SUPPLEMENTARY_GROUPS=${2}
			shift 2
			;;
		--locale)
			[[ $# -ge 2 ]] || die "--locale requires an argument"
			LOCALE=${2}
			shift 2
			;;
		--keymap)
			[[ $# -ge 2 ]] || die "--keymap requires an argument"
			KEYMAP=${2}
			shift 2
			;;
		--timezone)
			[[ $# -ge 2 ]] || die "--timezone requires an argument"
			TIMEZONE=${2}
			shift 2
			;;
		--network-match)
			[[ $# -ge 2 ]] || die "--network-match requires an argument"
			NETWORK_MATCH=${2}
			shift 2
			;;
		--network-dns)
			[[ $# -ge 2 ]] || die "--network-dns requires an argument"
			NETWORK_DNS=${2}
			shift 2
			;;
		--no-network)
			NO_NETWORK=yes
			shift
			;;
		--kernel-extra)
			[[ $# -ge 2 ]] || die "--kernel-extra requires an argument"
			KERNEL_EXTRA=${2}
			shift 2
			;;
		--bootloader)
			[[ $# -ge 2 ]] || die "--bootloader requires an argument"
			BOOTLOADER=${2}
			shift 2
			;;
		--grub-device)
			[[ $# -ge 2 ]] || die "--grub-device requires an argument"
			GRUB_DEVICE=${2}
			shift 2
			;;
		--grub-target)
			[[ $# -ge 2 ]] || die "--grub-target requires an argument"
			GRUB_TARGET=${2}
			shift 2
			;;
		--grub-boot-id)
			[[ $# -ge 2 ]] || die "--grub-boot-id requires an argument"
			GRUB_BOOT_ID=${2}
			shift 2
			;;
		--root-password-hash)
			[[ $# -ge 2 ]] || die "--root-password-hash requires an argument"
			ROOT_PASSWORD_HASH=${2}
			shift 2
			;;
		--user-password-hash)
			[[ $# -ge 2 ]] || die "--user-password-hash requires an argument"
			USER_PASSWORD_HASH=${2}
			shift 2
			;;
		--yes)
			YES=yes
			shift
			;;
		-h|--help)
			usage
			exit 0
			;;
		--*)
			die "unknown option: ${1}"
			;;
		*)
			[[ -z ${ROOT} ]] || die "unexpected positional argument: ${1}"
			ROOT=${1}
			shift
			;;
	esac

done

[[ -n ${ROOT} ]] || {
	usage >&2
	exit 2
}

ROOT=${ROOT%/}
[[ -n ${ROOT} ]] || ROOT=/
[[ -d ${ROOT} ]] || die "root does not exist: ${ROOT}"
ROOT=$(readlink -f "${ROOT}" 2>/dev/null || printf '%s\n' "${ROOT}")

require_command 1g4-system-setup
require_command findmnt
require_command blkid
require_command lsblk
require_command awk
require_command sort
if [[ ${ROOT} != / ]]; then
	require_command chroot
fi

INTERACTIVE=no
[[ ${YES} == yes ]] || { [[ -t 0 && -t 1 ]] && INTERACTIVE=yes; }

HOSTNAME=${HOSTNAME:-1g4}
TIMEZONE=${TIMEZONE:-$(default_timezone)}
if [[ -z ${NORMAL_USER} ]]; then
	NORMAL_USER=$(default_login_user || true)
fi
if [[ -z ${NORMAL_USER} && ${INTERACTIVE} == yes ]]; then
	NORMAL_USER=$(prompt_default 'Normal user name' '')
fi
[[ -n ${NORMAL_USER} ]] || die "normal user is required; pass --user"

if [[ ${INTERACTIVE} == yes ]]; then
	HOSTNAME=$(prompt_default 'Hostname' "${HOSTNAME}")
	TIMEZONE=$(prompt_default 'Timezone' "${TIMEZONE}")
fi

[[ -n ${HOSTNAME} ]] || die "hostname must not be empty"
[[ -n ${TIMEZONE} ]] || die "timezone must not be empty"
TIMEZONE=$(normalize_target_timezone "${TIMEZONE}")

TMPDIR=$(mktemp -d)
cleanup() {
	local status=$?
	if [[ ${status} -eq 0 ]]; then
		rm -rf "${TMPDIR}"
	else
		echo "[$(basename "$0")] keeping temp files at ${TMPDIR}" >&2
	fi
}
trap cleanup EXIT

MOUNT_TABLE=${TMPDIR}/mounts
FSTAB_FILE=${TMPDIR}/fstab
CRYPTTAB_FILE=${TMPDIR}/crypttab
CONFIG_FILE=${TMPDIR}/install.conf

collect_mount_table

declare -A CRYPT_UUID_BY_NAME=()
declare -a CRYPT_ORDER=()
declare -a PRESERVED_BIND_LINES=()
LUKS_USED=no

preserve_existing_bind_mounts
generate_fstab
validate_generated_fstab
write_crypttab
build_kernel_cmdline
detect_kernel_installation
build_boot_hooks

if [[ ${INTERACTIVE} == yes ]]; then
	if [[ -z ${USER_PASSWORD_HASH} ]]; then
		USER_PASSWORD_HASH=$(prompt_password_hash "Password for ${NORMAL_USER}" || true)
	fi
	if [[ -z ${ROOT_PASSWORD_HASH} ]]; then
		ROOT_PASSWORD_HASH=$(prompt_password_hash 'Root password' || true)
	fi
fi

: > "${CONFIG_FILE}"
write_config_var ONEG4_SETUP_HOSTNAME "${HOSTNAME}"
write_config_var ONEG4_SETUP_LOCALE "${LOCALE}"
write_config_var ONEG4_SETUP_KEYMAP "${KEYMAP}"
write_config_var ONEG4_SETUP_TIMEZONE "${TIMEZONE}"
write_config_var ONEG4_SETUP_FSTAB_FILE "${FSTAB_FILE}"
write_config_var ONEG4_SETUP_KERNEL_CMDLINE "${KERNEL_CMDLINE}"
write_config_var ONEG4_SETUP_NORMAL_USER "${NORMAL_USER}"
write_config_var ONEG4_SETUP_NORMAL_USER_SHELL "${USER_SHELL}"
write_config_var ONEG4_SETUP_NORMAL_USER_GROUPS "${SUPPLEMENTARY_GROUPS}"
write_config_var ONEG4_SETUP_REQUIRE_NORMAL_USER yes
write_config_var ONEG4_SETUP_REQUIRE_BOOT_ASSETS yes
write_config_var ONEG4_SETUP_LUKS_USED "${LUKS_USED}"
if [[ ${LUKS_USED} == yes ]]; then
	write_config_var ONEG4_SETUP_CRYPTTAB_FILE "${CRYPTTAB_FILE}"
fi
if [[ ${NO_NETWORK} != yes ]]; then
	write_config_var ONEG4_SETUP_NETWORKD_MATCH_NAMES "${NETWORK_MATCH}"
	write_config_var ONEG4_SETUP_NETWORKD_DHCP ipv4
	if [[ -n ${NETWORK_DNS} ]]; then
		write_config_var ONEG4_SETUP_NETWORKD_DNS "${NETWORK_DNS}"
	fi
fi
if [[ -n ${USER_PASSWORD_HASH} ]]; then
	write_config_var ONEG4_SETUP_NORMAL_USER_PASSWORD_HASH "${USER_PASSWORD_HASH}"
fi
if [[ -n ${ROOT_PASSWORD_HASH} ]]; then
	write_config_var ONEG4_SETUP_ROOT_PASSWORD_HASH "${ROOT_PASSWORD_HASH}"
fi
if [[ -n ${INITRAMFS_CMD} ]]; then
	write_config_var ONEG4_SETUP_INITRAMFS_CMD "${INITRAMFS_CMD}"
fi
if [[ -n ${BOOTLOADER_INSTALL_CMD} ]]; then
	write_config_var ONEG4_SETUP_BOOTLOADER_INSTALL_CMD "${BOOTLOADER_INSTALL_CMD}"
fi
if [[ -n ${BOOTLOADER_CONFIG_CMD} ]]; then
	write_config_var ONEG4_SETUP_BOOTLOADER_CONFIG_CMD "${BOOTLOADER_CONFIG_CMD}"
fi
if [[ -n ${BOOTLOADER_CONFIG} ]]; then
	write_config_var ONEG4_SETUP_BOOTLOADER_CONFIG "${BOOTLOADER_CONFIG}"
fi

show_summary
if [[ ${INTERACTIVE} == yes ]]; then
	read -r -p 'Continue and finalize install? [y/N]: ' reply || true
	case ${reply} in
		y|Y|yes|YES) ;;
		*) die 'aborted' ;;
	esac
fi

1g4-system-setup finalize "${ROOT}" installed-host "${CONFIG_FILE}"
log "system is finalized and validated as boot-ready"
