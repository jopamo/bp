OPT_FLAGS="-O0 -ggdb3"
GRAPHITE_FLAGS=""
LTO_FLAGS=""

FEATURES="${FEATURES} nostrip splitdebug"

BASE_FLAGS="${OPT_FLAGS} ${GRAPHITE_FLAGS} ${SECURITY_FLAGS} ${POSITION_FLAGS} ${LTO_FLAGS}"
CFLAGS="${MARCH} ${BASE_FLAGS} ${REPRO_FLAGS}"
CXXFLAGS="${CFLAGS}"
CPPFLAGS="${CFLAGS}"
FFLAGS="${CFLAGS}"
FCFLAGS="${CFLAGS}"
LDFLAGS="${LTO_FLAGS} ${POSITION_FLAGS} \
    -Wl,-O1 \
    -Wl,-z,relro -Wl,-z,now -Wl,--as-needed"
