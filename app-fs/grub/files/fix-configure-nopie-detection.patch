diff -urN a/acinclude.m4 b/acinclude.m4
--- a/acinclude.m4
+++ b/acinclude.m4
@@ -439,16 +439,16 @@
 [# Position independent executable.
 link_nopie_needed=no]
 AC_MSG_CHECKING([whether linker needs disabling of PIE to work])
-AC_LANG_CONFTEST([AC_LANG_SOURCE([[]])])
-
-[if eval "$ac_compile -Wl,-r -nostdlib -Werror -o conftest.o" 2> /dev/null; then]
-  AC_MSG_RESULT([no])
-  [# Should we clear up other files as well, having called `AC_LANG_CONFTEST'?
-  rm -f conftest.o
-else
-  link_nopie_needed=yes]
-  AC_MSG_RESULT([yes])
-[fi]
+AC_CACHE_VAL(grub_cv_cc_link_nopie_needed,
+[save_LDFLAGS="$LDFLAGS"
+LDFLAGS="$LDFLAGS -Wl,-r -nostdlib"
+AC_LINK_IFELSE([AC_LANG_PROGRAM([[]], [[]])],
+               [grub_cv_cc_link_nopie_needed=no],
+               [grub_cv_cc_link_nopie_needed=yes])
+LDFLAGS="$save_LDFLAGS"
+])
+link_nopie_needed="$grub_cv_cc_link_nopie_needed"
+AC_MSG_RESULT([$link_nopie_needed])
 ])
 
 
@@ -457,7 +457,7 @@
 [AC_MSG_CHECKING([whether linker accepts -no-pie])
 AC_CACHE_VAL(grub_cv_cc_ld_no_pie,
 [save_LDFLAGS="$LDFLAGS"
-LDFLAGS="$LDFLAGS -no-pie -nostdlib -Werror"
+LDFLAGS="$LDFLAGS -Wl,-no-pie -nostdlib"
 AC_LINK_IFELSE([AC_LANG_PROGRAM([[]], [[]])],
 	       [grub_cv_cc_ld_no_pie=yes],
 	       [grub_cv_cc_ld_no_pie=no])
@@ -474,7 +474,7 @@
 [AC_MSG_CHECKING([whether linker accepts -nopie])
 AC_CACHE_VAL(grub_cv_cc_ld_no_pie_oneword,
 [save_LDFLAGS="$LDFLAGS"
-LDFLAGS="$LDFLAGS -nopie -nostdlib -Werror"
+LDFLAGS="$LDFLAGS -Wl,-nopie -nostdlib"
 AC_LINK_IFELSE([AC_LANG_PROGRAM([[]], [[]])],
 	       [grub_cv_cc_ld_no_pie_oneword=yes],
 	       [grub_cv_cc_ld_no_pie_oneword=no])
diff -urN a/configure.ac b/configure.ac
--- a/configure.ac
+++ b/configure.ac
@@ -1645,10 +1645,10 @@
 
 if [ x"$link_nopie_needed" = xyes ] || [ x"$pie_possible" = xyes ]; then
   if [ x"$nopie_possible" = xyes ]; then
-    TARGET_LDFLAGS="$TARGET_LDFLAGS -no-pie"
+    TARGET_LDFLAGS="$TARGET_LDFLAGS -Wl,-no-pie"
   fi
   if [ x"$nopie_oneword_possible" = xyes ]; then
-    TARGET_LDFLAGS="$TARGET_LDFLAGS -nopie"
+    TARGET_LDFLAGS="$TARGET_LDFLAGS -Wl,-nopie"
   fi
 fi]
 
