_GOMODULE_GOPROXY_BASEURI="https://proxy.golang.org"
go-module_set_globals

SRC_URI+=" ${EGO_SUM_SRC_URI}"
S="${WORKDIR}/cli-${SNAPSHOT}"

LICENSE="MIT Apache-2.0 BSD BSD-2 MPL-2.0"
SLOT="0"
KEYWORDS="amd64 arm64"
BDEPEND+=" >=app-lang/go-1.26.20260305:="

RESTRICT="test"

# Build against the packaged Go toolchain and the fetched module distfiles only.
export GOSUMDB=off
export GOTOOLCHAIN=local

src_compile() {
	export GH_VERSION="snapshot-${PV}-${SHORT}"

	filter-flags "-flto*"
	filter-flags "-ggdb3"
	unset LDFLAGS

	emake

	einfo "Building man pages"
	emake manpages
}

src_install() {
	dobin bin/gh

	doman share/man/man?/gh*.?
}
